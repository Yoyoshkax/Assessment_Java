pipeline {
    agent any
    tools {
        maven 'Maven'
    }
    stages {
        stage('Build') {
            steps {
                echo 'Building..'
            }
        }
        stage('Test') {
            steps {
                echo 'Tests Started'
                sh 'mvn clean test'
            }
        }
        stage('Allure reports') {
            allure commandline: 'Allure',
                includeProperties: false,
                jdk: '',
                results: [[path: 'target/allure-results']]
        }
    }
}