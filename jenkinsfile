pipeline {
    agent any
    tools {
        maven 'Maven'
    }
    stages {
        stage('Build') {
            steps {
                echo 'Building..'
            }
        }
        stage('Test') {
            steps {
                echo 'Tests Started'
                catchError(buildResult: 'UNSTABLE', stageResult: 'FAILURE') {
                sh 'mvn clean test'
                }
            }
        }
        stage('Allure reports') {
            steps{
            allure commandline: 'Allure',
                 includeProperties: false,
                 jdk: '',
                 results: [[path: 'target/allure-results']]
            }
        }
    }
}